# =====================================
# Application
# =====================================

APP_NAME=SeedOpsLite
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.1.0

# =====================================
# Redis
# =====================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT_SECONDS=5
REDIS_MAX_CONNECTIONS=10

# =====================================
# Logging
# =====================================

LOG_LEVEL=INFO
LOG_JSON_FORMAT=true

#######################################
# Active Provider
#######################################

LLM_PROVIDER=google

#######################################
# Google
#######################################

GOOGLE_ENABLED=true
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# Legacy aliases (backward compatible)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

#######################################
# OpenAI
#######################################

OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=

#######################################
# Anthropic
#######################################

ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

#######################################
# Common Runtime
#######################################

LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=8192

# =====================================
# Runtime Resilience
# =====================================
RUNTIME_CACHE_SYNC_QUEUE_SIZE=1000
RUNTIME_QUEUE_WARNING_PERCENT=80
RUNTIME_SYNC_BATCH_SIZE=50
RUNTIME_SYNC_RETRY_INTERVAL_SECONDS=5
RUNTIME_SYNC_MAX_RETRIES=3
RUNTIME_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
RUNTIME_CIRCUIT_BREAKER_RECOVERY_SECONDS=30
RUNTIME_HALF_OPEN_MAX_PROBES=1
RUNTIME_RECOVERY_POLL_INTERVAL_SECONDS=5
RUNTIME_WORKER_SHUTDOWN_TIMEOUT_SECONDS=10
RUNTIME_QUEUE_MAX_EVENT_AGE_SECONDS=86400
RUNTIME_REDIS_PING_TIMEOUT_SECONDS=2
RUNTIME_SYNC_MAX_CONCURRENT_TASKS=1
RUNTIME_CACHE_DEFAULT_TTL_SECONDS=3600
RUNTIME_MEMORY_CACHE_MAX_ENTRIES=10000
RUNTIME_MEMORY_EVICTION_BATCH_SIZE=100
RUNTIME_MEMORY_CLEANUP_INTERVAL_SECONDS=60