# =====================================
# Application
# =====================================

APP_NAME=SeedOpsLite
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.1.0

# =====================================
# Redis
# =====================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT_SECONDS=5
REDIS_MAX_CONNECTIONS=10

# =====================================
# Logging
# =====================================

LOG_LEVEL=INFO
LOG_JSON_FORMAT=true

# =====================================
# LLM Gateway
# =====================================

LLM_PROVIDER=gemini
LLM_MAX_RETRIES=3
LLM_TIMEOUT=30
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=8192

# =====================================
# Gemini
# =====================================
GOOGLE_GENAI_USE_VERTEXAI=false

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash