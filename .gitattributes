# ============================================================================
# SafeSeed-Ops .gitattributes
# ============================================================================

# Auto-detect text files
* text=auto

# Source code
*.py     text eol=lf
*.md     text eol=lf
*.toml   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.sql    text eol=lf
*.txt    text eol=lf

# Shell scripts
*.sh     text eol=lf

# Windows scripts
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binary assets
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary